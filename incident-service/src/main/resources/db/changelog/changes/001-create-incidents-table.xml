<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="developer">
        <createTable tableName="incidents">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="date_create" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="date_closed" type="TIMESTAMP"/>
            <column name="analyst_id" type="BIGINT"/>
            <column name="initiator_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="VARCHAR(20)"/>
            <column name="category" type="VARCHAR(50)"/>
            <column name="responsible_service" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
